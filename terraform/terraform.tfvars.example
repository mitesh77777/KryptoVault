###############################################################################
# Enclave-Guard – Example Variables
# Copy this file to terraform.tfvars and customize as needed.
###############################################################################

aws_region   = "us-east-1"
project_name = "enclave-guard"
environment  = "dev"

# EC2 Configuration
instance_type = "m5a.xlarge"
# ami_id       = ""            # Leave empty for latest Amazon Linux 2023
# key_pair_name = "my-keypair" # Your existing EC2 key pair

# SSH Access – RESTRICT THIS IN PRODUCTION
allowed_ssh_cidrs = ["0.0.0.0/0"]

# KMS Configuration
kms_key_alias          = "enclave-guard-secp256k1"
kms_key_deletion_window = 7

# Enclave Attestation – UPDATE AFTER BUILDING EIF
# Run: nitro-cli describe-eif --eif-path enclave.eif
# Then paste the PCR0 hash here and re-apply Terraform
enclave_pcr0_hash = "PLACEHOLDER"
