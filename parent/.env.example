# ──────────────────────────────────────────────────────────────
# Enclave-Guard – Parent Application Environment
# Copy to .env and fill in your values
# ──────────────────────────────────────────────────────────────

# AWS
AWS_REGION=us-east-1
KMS_KEY_ID=alias/enclave-guard-hedera-key

# Hedera Testnet
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=0.0.XXXXX
HEDERA_OPERATOR_KEY=302e...

# Enclave vsock
ENCLAVE_CID=16
ENCLAVE_PORT=5000

# Server
PORT=8080
LOG_LEVEL=info

# HCS Audit Topic (created on first run if empty)
HCS_TOPIC_ID=
