###############################################################################
# Enclave-Guard – Parent Instance Environment Variables
# Copy to .env and fill in your values
###############################################################################

# AWS Configuration
AWS_REGION=us-east-1
KMS_KEY_ID=alias/enclave-guard-secp256k1

# Hedera Configuration (Testnet)
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=0.0.XXXXX
HEDERA_OPERATOR_KEY=302e020100300506032b657004220420...

# Target account for the scheduled transfer demo
HEDERA_TARGET_ACCOUNT=0.0.YYYYY

# Transfer amount in tinybars (1 HBAR = 100,000,000 tinybars)
TRANSFER_AMOUNT=100000000

# Enclave vsock configuration
ENCLAVE_CID=16
ENCLAVE_PORT=5000
